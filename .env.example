# =========================================================
# CRYPTO SCALPER - ENV CONFIG
# Copy this file to ".env" and fill in your OWN, ROTATED keys.
# NEVER commit the real ".env" file to GitHub (it is in .gitignore).
# All keys below are PLACEHOLDERS. Do not paste real secrets in chat,
# screenshots, or public repos ever again — rotate any key that was
# ever pasted somewhere outside your local machine.
# =========================================================

# ---- Binance TESTNET (spot: testnet.binance.vision, futures: testnet.binancefuture.com) ----
BINANCE_TESTNET_API_KEY=your_binance_testnet_api_key
BINANCE_TESTNET_API_SECRET=your_binance_testnet_api_secret
BINANCE_USE_FUTURES=true
BINANCE_USE_SPOT=true

# ---- Telegram notifications ----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ---- AI reasoning / journaling (Groq primary, Anthropic fallback) ----
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- GitHub auto-push (used only by scripts/auto_push.sh) ----
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO_URL=https://github.com/your-username/your-repo.git
GITHUB_BRANCH=main

# ---- Risk management ----
RISK_PER_TRADE_PCT=1.0
MIN_RISK_REWARD_RATIO=1.25
DAILY_LOSS_LIMIT_PCT=5.0
MAX_CONCURRENT_TRADES=3
MAX_TRADES_PER_DAY=40
MAX_HOLD_MINUTES=45

# ---- Strategy / scanner ----
TOP_GAINERS_COUNT=15
MIN_24H_QUOTE_VOLUME_USDT=5000000
SCAN_INTERVAL_SECONDS=30
KLINE_INTERVAL=5m

# ---- Dashboard ----
DASHBOARD_PORT=5000
